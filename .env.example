# ── Telegram Bot ──────────────────────────────────────────
# Create a bot: message @BotFather on Telegram → /newbot → copy the token
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (comma-separated for multiple users)
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=

# ── Server ────────────────────────────────────────────────
# Web viewer port
PORT=3000

# ── API Security ──────────────────────────────────────────
# API key for /api/v1/* endpoints (leave empty to disable auth)
API_KEY=

# JWT secret for token-based auth (leave empty to disable JWT)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=

# ── Logging ───────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ── CDP ───────────────────────────────────────────────────
# Comma-separated CDP ports to scan for Antigravity
CDP_PORTS=9000,9001,9002,9003

# ── Launcher ──────────────────────────────────────────────
# Command to launch Antigravity IDE (auto-detected: antigravity, cursor, code)
ANTIGRAVITY_CMD=antigravity

# Discovery interval (ms) — how often to scan for new Antigravity windows
DISCOVERY_INTERVAL=10000

# Poll interval (ms) — how often to capture HTML snapshots
POLL_INTERVAL=3000

# Monitor interval (ms) — how often to check agent activity phase
MONITOR_INTERVAL=2000
